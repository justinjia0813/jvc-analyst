{
  "schema_version": 1,
  "description": "Deterministic output-contract checks for the first jvc skill eval pass. These are fixture checks, not model-executed evidence.",
  "cases": [
    {
      "id": "prescreen-markdown-contract",
      "skill": "jvc-prescreen",
      "artifact_family": "markdown",
      "assertions": [
        {"type": "file_exists", "path": "examples/prescreen-example.md"},
        {"type": "contains", "path": "examples/prescreen-example.md", "text": "## 一页事实摘要"},
        {"type": "contains", "path": "examples/prescreen-example.md", "text": "## 七维初筛判断"},
        {"type": "contains", "path": "examples/prescreen-example.md", "text": "## Bear Case 雏形"},
        {"type": "contains_any", "path": "examples/prescreen-example.md", "texts": ["[未核实]", "[需要用户提供]"]},
        {"type": "not_contains_any", "path": "examples/prescreen-example.md", "texts": ["建议投资", "不建议投资"]}
      ]
    },
    {
      "id": "track-research-markdown-contract",
