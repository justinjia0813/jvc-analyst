        {"type": "contains", "path": "examples/track-research-example.md", "text": "### 四性初判与可证伪假设"},
        {"type": "contains", "path": "examples/track-research-example.md", "text": "### 周期位置矩阵"},
        {"type": "contains", "path": "examples/track-research-example.md", "text": "核心因果链"},
        {"type": "contains", "path": "examples/track-research-example.md", "text": "关键反证"},
