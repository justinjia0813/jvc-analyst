        {"type": "contains", "path": "examples/track-research-example.md", "text": "## 来源索引"},
        {"type": "contains_any", "path": "examples/track-research-example.md", "texts": ["[S1]", "[S4]", "[未核实]"]},
        {"type": "not_contains_any", "path": "examples/track-research-example.md", "texts": ["万亿级市场", "建议投资", "不建议投资"]}
      ]
